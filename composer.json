{
    "name": "sigstore/sigstore-php",
    "description": "PHP SDK for Sigstore",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Sigstore Community"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-bcmath": "*",
        "google/protobuf": "^3.21 || ^4.21",
        "guzzlehttp/guzzle": "^7.0",
        "league/oauth2-client": "^2.6",
        "symfony/console": "^6.0 || ^7.0",
        "fgrosse/phpasn1": "^2.5",
        "phpseclib/phpseclib": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sigstore\\": "src/",
            "Dev\\Sigstore\\": "src/Proto/Dev/Sigstore/",
            "Google\\Api\\": "src/Proto/Google/Api/",
            "Google\\Protobuf\\": "src/Proto/Google/Protobuf/",
            "GPBMetadata\\": "src/Proto/GPBMetadata/",
            "Io\\Intoto\\": "src/Proto/Io/Intoto/"
        },
        "classmap": [
            "bin/"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    }
}
